def run_test_set(urls: list[tuple[str, str]] = TEST_URLS) -> pd.DataFrame:
    """Draai de pipeline op een mini-testset (zonder Excel-input).

    Handig om de extractielogica te valideren voordat je de volledige batch
    draait. Schrijft resultaten naar `test_output.xlsx`/`.csv`.
    """
    rows = [{
        "KoepelOrganisatie": "TEST",
        "steekproef": "test",
        "Naam Burgercollectief": naam,
        "Website": url,
    } for naam, url in urls]
    df_in = pd.DataFrame(rows)
    df_in["Website"] = df_in["Website"].map(clean_url)
    try:
        df_out, df_log = run_pipeline(df_in)
        save_output(df_out, df_log,
                    xlsx_path="test_output.xlsx",
                    csv_path="test_output.csv")
