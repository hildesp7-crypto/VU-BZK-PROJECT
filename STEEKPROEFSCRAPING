# =============================================================================

def _context_window(text: str, match: re.Match, before: int = 80,
                    after: int = 80) -> str:
    """Geef de tekst-context rond een regex-match in lowercase."""
    s = max(0, match.start() - before)
    e = min(len(text), match.end() + after)
    return text[s:e].lower()


def extract_kvk(text: str) -> Optional[str]:
    """Vind KvK-nummer (exact 8 cijfers) met context-validatie.

    Vereist dat 'kvk', 'kamer van koophandel' of 'handelsregister' binnen
    ±80 tekens van het nummer staat — voorkomt valse positieven op
    telefoonnummers of postcodes.
    """
    # 1. Directe match met label vóór het nummer
    pat = re.compile(
        r"(?:kvk[\s\-:.]*(?:nummer|nr|num)?|kamer\s+van\s+koophandel|"
        r"handelsregister)[\s\-:.,]*?(\d{8})\b",
        re.IGNORECASE,
    )
    m = pat.search(text)
    if m:
        return m.group(1)

    # 2. Fallback: elk 8-cijferig getal met kvk-keyword in venster
    keywords = ("kvk", "kamer van koophandel", "handelsregister")
    for m in re.finditer(r"(?<!\d)(\d{8})(?!\d)", text):
        ctx = _context_window(text, m)
        if any(k in ctx for k in keywords):
            return m.group(1)
    return None


def extract_rsin(text: str) -> Optional[str]:
    """Vind RSIN (exact 9 cijfers) met context-validatie."""
    pat = re.compile(
        r"(?:rsin|fiscaal\s*nummer|fiscaalnummer|"
        r"fiscaal\s*identificatienummer)[\s\-:.,]*?(\d{9})\b",
        re.IGNORECASE,
    )
    m = pat.search(text)
    if m:
        return m.group(1)

    keywords = ("rsin", "fiscaal nummer", "fiscaalnummer", "fiscaal-nummer",
                "fiscaal identificatienummer")
    for m in re.finditer(r"(?<!\d)(\d{9})(?!\d)", text):
        ctx = _context_window(text, m)
        if any(k in ctx for k in keywords):
            return m.group(1)
    return None


def extract_btw(text: str) -> Optional[str]:
    """Vind BTW-nummer (formaat: NL + 9 cijfers + B + 2 cijfers)."""
    m = re.search(r"\b(NL\s?\d{9}\s?B\s?\d{2})\b", text, re.IGNORECASE)
    if m:
        return re.sub(r"\s+", "", m.group(1)).upper()
    # Met context
    m = re.search(r"btw[\s\-:.\w]{0,30}?(NL\s?\d{9}\s?B\s?\d{2})",
                  text, re.IGNORECASE)
    if m:
        return re.sub(r"\s+", "", m.group(1)).upper()
    return None


def extract_members_only(text: str) -> str:
    """Bepaal of het collectief exclusief voor leden is."""
    t = text.lower()
    yes_kw = (
        "alleen voor leden", "uitsluitend voor leden", "uitsluitend leden",
        "alleen leden", "besloten gemeenschap", "besloten cooperatie",
        "besloten coöperatie", "ledenwebsite", "ledenportaal",
        "inloggen voor leden", "alleen toegankelijk voor leden",
        "alleen leden hebben toegang",
    )
    no_kw = (
        "iedereen welkom", "open voor iedereen", "voor iedereen toegankelijk",
        "open gemeenschap", "openbaar toegankelijk",
    )
    if any(k in t for k in yes_kw):
        return "Ja"
    if any(k in t for k in no_kw):
        return "Nee"
    return "Onbekend"


def extract_winstoogmerk(text: str) -> str:
    """Bepaal of de organisatie winstoogmerk heeft.

    Sterke signalen voor 'Nee': expliciete vermelding 'zonder winstoogmerk',
    'non-profit', ANBI-status. Zwakke signalen: stichting / vereniging /
    coöperatie. Sterke 'Ja': 'met winstoogmerk', BV / NV-vermelding.
    """
    t = text.lower()
    strong_no = (
        "zonder winstoogmerk", "geen winstoogmerk", "non-profit", "non profit",
        "nonprofit", "algemeen nut beogende instelling", "anbi-status",
        "anbi status", "anbi-instelling",
    )
    weak_no = (
        "stichting", "vereniging", "coöperatie", "cooperatie",
    )
    strong_yes = (
        "met winstoogmerk", "commerciële onderneming", "winstgevend bedrijf",
    )
    # \b werkt niet correct na een '.' (zoals in 'b.v.'); expliciete boundaries:
    legal_yes = re.search(
        r"(?:^|[\s\(])(b\.?v\.?|n\.?v\.?)(?:[\s,;.\)!?]|$)", t)

    if any(k in t for k in strong_yes):
        return "Ja"
    if any(k in t for k in strong_no):
        return "Nee"
    if any(k in t for k in weak_no):
        return "Nee"
    if legal_yes:
        return "Ja"
    return "Onbekend"


def extract_volunteers(text: str) -> str:
    """Bepaal of het collectief (deels) met vrijwilligers werkt."""
    t = text.lower()
    yes_kw = (
        "vrijwilliger", "vrijwilligerswerk", "onbezoldigd",
        "vrijwillige inzet", "door vrijwilligers", "met vrijwilligers",
        "onze vrijwilligers", "vrijwilligers-",
    )
    if any(k in t for k in yes_kw):
        return "Ja"
    return "Onbekend"


def extract_jaarverslag(crawl: CrawlResult) -> Optional[str]:
    """Zoek URL naar het meest recente jaarverslag.

    Doorzoekt alle `<a>`-tags op alle pagina's; scoort kandidaten op
    bestandstype (PDF > HTML), jaartal en context (ANBI/transparantie).
    """
    year_pat = re.compile(r"20(2[0-6]|1[5-9])")
    candidates: list[tuple[float, str]] = []
    keywords_link = ("jaarverslag", "jaarrekening", "annual report",
                     "annual-report", "year report")

    for page_url, soup in crawl.soups.items():
        page_is_anbi = ("anbi" in page_url.lower()
                        or "transparantie" in page_url.lower())
        for a in soup.find_all("a", href=True):
            href = a["href"].strip()
            link_text = a.get_text(" ", strip=True).lower()
            combined = f"{href.lower()} {link_text}"
            if not any(k in combined for k in keywords_link):
                continue
            abs_url = urlparse.urljoin(page_url, href)
            if not abs_url.startswith(("http://", "https://")):
                continue
            # PDF of HTML, beide acceptabel; voorkeur PDF.
            is_pdf = abs_url.lower().endswith(".pdf")
            year_match = year_pat.search(combined)
            year = int(f"20{year_match.group(1)}") if year_match else 0
            same_domain = is_same_registered_domain(abs_url, page_url)
            score = (year * 10
                     + (5 if is_pdf else 0)
                     + (3 if page_is_anbi else 0)
                     + (2 if same_domain else -10))
            candidates.append((score, abs_url))

    # Ook gevonden PDF's in de crawl-output die niet via een link zijn benoemd
    for pdf_url in crawl.pdfs:
        if any(k in pdf_url.lower() for k in keywords_link):
            year_match = year_pat.search(pdf_url)
            year = int(f"20{year_match.group(1)}") if year_match else 0
            candidates.append((year * 10 + 5, pdf_url))

    if not candidates:
        return None
    candidates.sort(reverse=True)
    return candidates[0][1]


def _find_place_match(text: str, lookup: dict[str, str]) -> Optional[str]:
    """Zoek de eerste plaats uit `lookup` (case-insensitive) in `text`.

    Geeft de canonieke (originele) schrijfwijze terug.
    """
    t = text.lower()
    # Sorteren op lengte zodat we eerst meer-woord-namen matchen.
    for key in sorted(lookup.keys(), key=len, reverse=True):
        # Word-boundary match
        if re.search(rf"\b{re.escape(key)}\b", t):
            return lookup[key]
    return None


def extract_vestigingsplaats(text: str) -> Optional[str]:
    """Vind vestigingsplaats: Nederlandse gemeente in adres-/contactcontext."""
    # 1. Probeer expliciete context: 'gevestigd te', 'vestigingsplaats:'
    for ctx_pat in (
        r"(?:gevestigd\s+(?:te|in)|vestigingsplaats|statutair\s+gevestigd"
        r"\s+(?:te|in)|gevestigd:?)[\s:.,]+([A-ZÀ-Ÿ][\w\-\' ]{2,40})",
    ):
        m = re.search(ctx_pat, text, re.IGNORECASE)
        if m:
            candidate = m.group(1).strip().rstrip(".,;:")
            # Verifieer tegen gemeentelijst
            for word in (candidate, candidate.split()[0]):
                hit = _find_place_match(word, _GEMEENTEN_LOOKUP)
                if hit:
                    return hit
    # 2. Postcode-pattern (\d{4} ?[A-Z]{2}) gevolgd door plaats
    pc_pat = re.compile(r"\b\d{4}\s?[A-Z]{2}\s+([A-ZÀ-Ÿ][\w\-\' ]{2,40})",
                        re.IGNORECASE)
    m = pc_pat.search(text)
    if m:
        candidate = m.group(1).strip().rstrip(".,;:")
        hit = _find_place_match(candidate, _GEMEENTEN_LOOKUP)
        if hit:
            return hit
    # 3. Fallback: eerste gemeente die überhaupt voorkomt
    return _find_place_match(text, _GEMEENTEN_LOOKUP)


def extract_werkgebied(text: str) -> Optional[str]:
    """Bepaal het geografische werkgebied: gemeente, regio, provincie of landelijk."""
    t = text.lower()
    # 1. Landelijk
    if re.search(r"\blandelijk(?:\s+(?:actief|werkzaam))?\b", t) \
            or "heel nederland" in t or "in heel nederland" in t:
        return "Landelijk (Nederland)"
    # 2. Werkgebied met expliciete context
    m = re.search(
        r"(?:werkgebied|actief\s+in|werkzaam\s+in|werken\s+in)[\s:.,]+"
        r"([A-ZÀ-Ÿ][\w\-\' ,]{2,80})",
        text, re.IGNORECASE)
    if m:
        candidate = m.group(1).strip()
        for lookup in (_GEMEENTEN_LOOKUP, _REGIOS_LOOKUP, _PROVINCIES_LOOKUP):
            hit = _find_place_match(candidate, lookup)
            if hit:
                return hit
        # Anders eerste 60 chars van de context
        return candidate[:60].rstrip(".,;:")
    # 3. Match tegen provincie/regio elders in de tekst
    for lookup in (_PROVINCIES_LOOKUP, _REGIOS_LOOKUP):
        hit = _find_place_match(text, lookup)
        if hit:
            return hit
    return None


def extract_sectorcode(text: str) -> Optional[str]:
    """Vind SBI-code (4 of 5 cijfers met context)."""
    pat = re.compile(r"sbi[\s\-:.]*(?:code)?[\s\-:.]*(\d{4,5})\b",
                     re.IGNORECASE)
    m = pat.search(text)
    if m:
        return m.group(1)
    # Variant: 'sectorcode' / 'bedrijfscode'
    pat2 = re.compile(r"(?:sectorcode|bedrijfscode)[\s\-:.]*(\d{4,5})\b",
                      re.IGNORECASE)
    m = pat2.search(text)
    if m:
        return m.group(1)
    return None


