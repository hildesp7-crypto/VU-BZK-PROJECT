REQUIRED_INPUT_COLS = ("KoepelOrganisatie", "steekproef",
                       "Naam Burgercollectief", "Website")


def load_input(path: str = INPUT_PATH) -> pd.DataFrame:
    """Laad het input-Excelbestand en valideer de kolommen."""
    log.info("Inlezen: %s", path)
    df = pd.read_excel(path, dtype=str)
    df.columns = [c.strip() for c in df.columns]
    missing = [c for c in REQUIRED_INPUT_COLS if c not in df.columns]
    if missing:
        raise ValueError(
            f"Verwachte kolom(men) ontbreken in {path}: {missing}. "
            f"Aanwezig: {list(df.columns)}")
    # Schoon URLs
    df["Website"] = df["Website"].map(clean_url)
    return df


def save_output(df_main: pd.DataFrame, df_log: pd.DataFrame,
                xlsx_path: str = OUTPUT_XLSX,
                csv_path: str = OUTPUT_CSV) -> None:
    """Schrijf resultaten naar Excel (2 sheets: 'data' + 'log') en CSV."""
    log.info("Schrijven: %s", xlsx_path)
    with pd.ExcelWriter(xlsx_path, engine="openpyxl") as writer:
        df_main.to_excel(writer, sheet_name="data", index=False)
        df_log.to_excel(writer, sheet_name="log", index=False)
        # Kolombreedte automatisch ruim instellen (cap op 60)
        for sheet_name, df in (("data", df_main), ("log", df_log)):
            ws = writer.sheets[sheet_name]
            for i, col in enumerate(df.columns, start=1):
                max_len = max(
                    [len(str(col))] +
                    [min(60, len(str(v))) for v in df[col].head(200).tolist()
                     if v is not None]
                )
                ws.column_dimensions[ws.cell(row=1, column=i).column_letter].width = (
                    min(60, max(12, max_len + 2)))
    log.info("Schrijven: %s", csv_path)
    df_main.to_csv(csv_path, index=False, encoding="utf-8-sig")


# %%
# =============================================================================
# Main — orchestratie
# =============================================================================

def run_pipeline(df_input: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:
    """Verwerk alle rijen in `df_input` en geef (main_df, log_df) terug."""
    df = df_input.copy()
    for col in NEW_COLUMNS:
        if col not in df.columns:
            df[col] = ""

    log_rows: list[dict] = []

    iterator = tqdm(df.iterrows(), total=len(df), desc="Initiatieven", unit="site")
    for idx, row in iterator:
        naam = str(row.get("Naam Burgercollectief", "") or "").strip()
        url = str(row.get("Website", "") or "").strip()
        if not url:
            log.warning("Rij %d (%s): geen URL — overgeslagen", idx, naam)
            log_rows.append({
                "Naam Burgercollectief": naam, "Website": url,
                "Pagina's bezocht": 0, "Pagina's lijst": "",
                "Velden gevonden": "", "Foutmeldingen": "Geen URL",
            })
            continue
        try:
            res = process_site(naam, url)
        except Exception as e:                        # noqa: BLE001
            log.error("Onverwachte fout bij %s: %s", naam, e)
            log_rows.append({
                "Naam Burgercollectief": naam, "Website": url,
                "Pagina's bezocht": 0, "Pagina's lijst": "",
                "Velden gevonden": "", "Foutmeldingen": f"Fataal: {e}",
            })
            continue

        for col, val in res.extracted.items():
            df.at[idx, col] = val

        log_rows.append({
            "Naam Burgercollectief": naam,
            "Website": url,
            "Pagina's bezocht": len(res.visited_pages),
            "Pagina's lijst": " | ".join(res.visited_pages[:30]),
            "Velden gevonden": ", ".join(res.found_fields),
            "Foutmeldingen": " | ".join(res.errors[:10]),
        })

    # Sorteer kolomvolgorde: oorspronkelijke + nieuwe (in gevraagde volgorde)
    ordered = list(REQUIRED_INPUT_COLS) + list(NEW_COLUMNS)
    # Extra kolommen uit input behouden achteraan
    extras = [c for c in df.columns if c not in ordered]
    df = df[[c for c in ordered if c in df.columns] + extras]

    df_log = pd.DataFrame(log_rows)
    return df, df_log


def main() -> None:
    """Lees input, draai pipeline, schrijf output. Sluit playwright netjes af."""
    try:
        df_input = load_input(INPUT_PATH)
        log.info("Aantal initiatieven: %d", len(df_input))
        df_out, df_log = run_pipeline(df_input)
        save_output(df_out, df_log)
        log.info("Klaar. %d rijen verwerkt.", len(df_out))
    finally:
        PW_FETCHER.close()


