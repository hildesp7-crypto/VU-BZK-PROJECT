# =============================================================================
# Playwright-fallback voor JS-zware sites
# =============================================================================

class PlaywrightFetcher:
    """Lazy-initialised playwright browser; één instantie hergebruiken."""

    def __init__(self) -> None:
        self._pw = None
        self._browser = None
        self._enabled = HAS_PLAYWRIGHT and USE_PLAYWRIGHT_FALLBACK

    def fetch(self, url: str) -> Optional[FetchResult]:
        """Haal `url` op met een echte browser. Return None bij fout/uitgeschakeld."""
        if not self._enabled:
            return None
        try:
            if self._pw is None:
                self._pw = sync_playwright().start()
                self._browser = self._pw.chromium.launch(headless=True)
                log.info("Playwright-browser gestart (eenmalig)")
            ctx = self._browser.new_context(user_agent=USER_AGENT, locale="nl-NL")
            page = ctx.new_page()
            page.set_default_timeout(REQUEST_TIMEOUT * 1000)
            page.goto(url, wait_until="networkidle", timeout=REQUEST_TIMEOUT * 2000)
            html = page.content()
            ctx.close()
            content = html.encode("utf-8")
            cache_put(url, content)
            return FetchResult(url=url, status=200, content=content,
                               content_type="text/html", from_cache=False)
        except PWTimeoutError as e:
            log.warning("Playwright timeout op %s: %s", url, e)
            return None
        except Exception as e:                      # noqa: BLE001 — fallback nooit fataal
            log.warning("Playwright-fout op %s: %s", url, e)
            return None

    def close(self) -> None:
        """Sluit de browser netjes af."""
        try:
            if self._browser:
                self._browser.close()
            if self._pw:
                self._pw.stop()
        except Exception:                            # noqa: BLE001
            pass


PW_FETCHER = PlaywrightFetcher()


def needs_playwright(result: FetchResult) -> bool:
    """Heuristiek: heeft deze pagina JS-rendering nodig?"""
    if not result.is_html or result.status != 200:
        return False
    try:
        soup = BeautifulSoup(result.content, "lxml")
    except Exception:                                # noqa: BLE001
        return False
    text = soup.get_text(" ", strip=True)
    if len(text) < PLAYWRIGHT_TRIGGER_BODY_CHARS:
        # SPA-markers in lege body
        spa_markers = ('id="root"', 'id="app"', 'ng-app', 'data-reactroot',
                       'window.__NUXT__', 'window.__INITIAL_STATE__')
        html_str = result.content.decode("utf-8", errors="ignore").lower()
        return any(m.lower() in html_str for m in spa_markers) or len(text) < 100
    return False


def fetch_smart(url: str) -> FetchResult:
    """Fetch met automatische playwright-fallback bij dunne HTML."""
    result = fetch(url)
    if result.status == 200 and result.is_html and needs_playwright(result):
        log.info("Statische scrape leverde te weinig content voor %s — playwright proberen",
                 url)
        pw_result = PW_FETCHER.fetch(url)
        if pw_result is not None and len(pw_result.text) > len(result.text):
            return pw_result
    return result


