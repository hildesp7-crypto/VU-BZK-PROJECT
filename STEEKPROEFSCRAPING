def extract_text_from_pdf(result: FetchResult) -> str:
    """Extraheer tekst uit een PDF-FetchResult met pdfplumber."""
    if not HAS_PDFPLUMBER:
        return ""
    try:
        import io as _io
        with pdfplumber.open(_io.BytesIO(result.content)) as pdf:
            parts: list[str] = []
            for page in pdf.pages[:30]:                # max 30 pagina's per PDF
                txt = page.extract_text() or ""
                parts.append(txt)
            return "\n".join(parts)
    except Exception as e:                            # noqa: BLE001
        log.debug("PDF-parse-fout %s: %s", result.url, e)
        return ""


