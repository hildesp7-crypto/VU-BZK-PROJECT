@dataclass
class SiteResult:
    """Verzamelt extractieresultaten en log-info voor één burgerinitiatief."""
    naam: str
    url: str
    extracted: dict[str, str] = field(default_factory=dict)
    visited_pages: list[str] = field(default_factory=list)
    found_fields: list[str] = field(default_factory=list)
    errors: list[str] = field(default_factory=list)


def _all_text(crawl: CrawlResult) -> str:
    """Combineer tekst van alle pagina's en PDF's tot één doorzoekbare blob."""
    return "\n".join(list(crawl.pages.values()) + list(crawl.pdfs.values()))


def process_site(naam: str, url: str) -> SiteResult:
    """Crawl één site en extraheer alle gevraagde velden."""
    result = SiteResult(naam=naam, url=url)
    if not url:
        result.errors.append("Geen URL opgegeven")
        return result

    log.info("→ %s  (%s)", naam, url)
    try:
        crawl = crawl_site(url)
    except Exception as e:                            # noqa: BLE001
        log.error("Crawl-fout voor %s: %s", url, e)
        result.errors.append(f"Crawl: {e}")
        return result

    result.visited_pages = list(crawl.pages.keys()) + list(crawl.pdfs.keys())
    result.errors.extend(crawl.errors)

    text_all = _all_text(crawl)
    if not text_all:
        result.errors.append("Geen content opgehaald")
        # Alle nieuwe kolommen blijven leeg / Onbekend
        for col in NEW_COLUMNS:
            result.extracted[col] = "" if col not in (
                "Exclusief voor leden", "Winstoogmerk", "Vrijwillig"
            ) else "Onbekend"
        result.extracted["KVK van website"] = "Nee"
        result.extracted["RSIN van website"] = "Nee"
        result.extracted["Jaarverslag"] = "Niet gevonden"
        result.extracted["Opmerking"] = "Geen content opgehaald (site offline of geblokkeerd?)"
        return result

    # Tekst alleen van website-HTML — voor 'KvK van website' / 'RSIN van website'
    text_website_only = "\n".join(crawl.pages.values())

    # Extracteer alle velden
    kvk = extract_kvk(text_all)
    rsin = extract_rsin(text_all)
    btw = extract_btw(text_all)
    kvk_on_website = extract_kvk(text_website_only) is not None
    rsin_on_website = extract_rsin(text_website_only) is not None

    members_only = extract_members_only(text_all)
    winstoogmerk = extract_winstoogmerk(text_all)
    vrijwillig = extract_volunteers(text_all)
    jaarverslag = extract_jaarverslag(crawl)
    werkgebied = extract_werkgebied(text_all)
    sectorcode = extract_sectorcode(text_all)
    vestigingsplaats = extract_vestigingsplaats(text_all)

    # RSIN/BTW-kolom: combineer beide indien gevonden, anders wat er is.
    rsin_btw_value = ""
    parts = []
    if rsin:
        parts.append(f"RSIN: {rsin}")
    if btw:
        parts.append(f"BTW: {btw}")
    rsin_btw_value = " | ".join(parts)

    result.extracted = {
        "KvK-Nummer": kvk or "",
        "RSIN/BTW nummer": rsin_btw_value,
        "RSIN": rsin or "",
        "Exclusief voor leden": members_only,
        "Winstoogmerk": winstoogmerk,
        "Opmerking": "",   # vullen we hieronder met wat er ontbreekt
        "Jaarverslag": jaarverslag or "Niet gevonden",
        "Werkgebied": werkgebied or "",
        "Sectorcode": sectorcode or "",
        "Vestigingsplaats": vestigingsplaats or "",
        "Vrijwillig": vrijwillig,
        "KVK van website": "Ja" if kvk_on_website else "Nee",
        "RSIN van website": "Ja" if rsin_on_website else "Nee",
    }

    # Bouw Opmerking met wat ontbreekt
    missing: list[str] = []
    if not kvk:
        missing.append("KvK-nummer")
    if not rsin and not btw:
        missing.append("RSIN/BTW")
    if not jaarverslag:
        missing.append("jaarverslag")
    if not vestigingsplaats:
        missing.append("vestigingsplaats")
    if not werkgebied:
        missing.append("werkgebied")
    if not sectorcode:
        missing.append("SBI-code (zelden op website vermeld)")
    if missing:
        result.extracted["Opmerking"] = "Ontbrekend op website: " + ", ".join(missing)
    else:
        result.extracted["Opmerking"] = "Alle hoofdvelden gevonden."

    # Found-fields voor de log
    for col, val in result.extracted.items():
        if val and val not in ("Onbekend", "Niet gevonden", "Nee"):
            result.found_fields.append(col)

    return result


