# =============================================================================
# URL-utilities
# =============================================================================

def clean_url(raw: str) -> str:
    """Strip Markdown-link-syntax en voeg schema toe als dat ontbreekt.

    Voorbeelden:
      "[www.voorbeeld.nl](https://www.voorbeeld.nl)" -> "https://www.voorbeeld.nl"
      "www.voorbeeld.nl" -> "https://www.voorbeeld.nl"
    """
    if raw is None or (isinstance(raw, float) and pd.isna(raw)):
        return ""
    url = str(raw).strip()
    md = re.match(r"\[.*?\]\((.+?)\)", url)
    if md:
        url = md.group(1).strip()
    if not url:
        return ""
    if not url.startswith(("http://", "https://")):
        url = "https://" + url
    return url


def get_registered_domain(url: str) -> str:
    """Geef het 'eTLD+1'-domein terug (bv. 'boschgaard.nl')."""
    ext = tldextract.extract(url)
    if not ext.suffix:
        return ext.domain
    return f"{ext.domain}.{ext.suffix}"


def is_same_registered_domain(url1: str, url2: str) -> bool:
    """True als beide URL's hetzelfde geregistreerde domein delen."""
    return get_registered_domain(url1) == get_registered_domain(url2) and bool(
        get_registered_domain(url1))


def url_path_lower(url: str) -> str:
    """Geef het pad-deel van een URL in lowercase, zonder query/fragment."""
    return urlparse.urlsplit(url).path.lower()


def hash_url(url: str) -> str:
    """Korte SHA1-hash van een URL, bruikbaar als bestandsnaam."""
    return hashlib.sha1(url.encode("utf-8")).hexdigest()[:16]


# %%
# =============================================================================
# Cache — bestand-gebaseerd, per domein
# =============================================================================

def cache_paths(url: str) -> tuple[Path, Path]:
    """Geef (content_path, meta_path) terug voor een gegeven URL."""
    domain = get_registered_domain(url) or "_unknown_"
    folder = CACHE_DIR / domain
    folder.mkdir(parents=True, exist_ok=True)
    base = folder / hash_url(url)
    # Extensie bepalen op basis van URL
    ext = ".pdf" if url.lower().endswith(".pdf") else ".html"
    return base.with_suffix(ext), base.with_suffix(".meta")


def cache_get(url: str) -> Optional[bytes]:
    """Lees gecachete content voor `url` of None als die niet bestaat."""
    content_path, _ = cache_paths(url)
    if content_path.exists():
        try:
            return content_path.read_bytes()
        except OSError as e:
            log.debug("Cache-leesfout %s: %s", content_path, e)
    return None


def cache_put(url: str, content: bytes) -> None:
    """Sla `content` op in de cache onder de bijbehorende URL-locatie."""
    content_path, meta_path = cache_paths(url)
    try:
        content_path.write_bytes(content)
        meta_path.write_text(f"{url}\n{time.time()}\n", encoding="utf-8")
    except OSError as e:
        log.debug("Cache-schrijffout %s: %s", content_path, e)


# %%
# =============================================================================
# HTTP-sessie met retries + robots.txt
# =============================================================================

_robots_cache: dict[str, Optional[robotparser.RobotFileParser]] = {}
_last_fetch_per_domain: dict[str, float] = {}


def make_session() -> requests.Session:
    """Maak één requests.Session met sane defaults en automatische retries."""
    sess = requests.Session()
    sess.headers.update({
        "User-Agent": USER_AGENT,
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "nl,en;q=0.8",
    })
    retry = Retry(
        total=MAX_RETRIES,
        backoff_factor=1.5,                    # 1.5s, 3s, 6s
        status_forcelist=(429, 500, 502, 503, 504),
        allowed_methods=("GET", "HEAD"),
        raise_on_status=False,
    )
    adapter = HTTPAdapter(max_retries=retry, pool_connections=4, pool_maxsize=4)
    sess.mount("http://", adapter)
    sess.mount("https://", adapter)
    return sess


SESSION = make_session()


def robots_allows(url: str) -> bool:
    """Controleer robots.txt voor `url`. Faalt veilig (True) bij fouten."""
    domain_key = urlparse.urlsplit(url).netloc
    if not domain_key:
        return True
    if domain_key not in _robots_cache:
        rp = robotparser.RobotFileParser()
        robots_url = urlparse.urlunsplit(
            (urlparse.urlsplit(url).scheme or "https", domain_key, "/robots.txt", "", ""))
        try:
            resp = SESSION.get(robots_url, timeout=REQUEST_TIMEOUT)
            if resp.status_code == 200:
                rp.parse(resp.text.splitlines())
                _robots_cache[domain_key] = rp
            else:
                _robots_cache[domain_key] = None
        except requests.RequestException as e:
            log.debug("robots.txt niet ophaalbaar voor %s: %s", domain_key, e)
            _robots_cache[domain_key] = None
    rp = _robots_cache[domain_key]
    if rp is None:
        return True
    return rp.can_fetch(USER_AGENT, url)


def polite_wait(url: str) -> None:
    """Wacht zodat we per domein hooguit één request per REQUEST_DELAY_SECONDS doen."""
    domain = get_registered_domain(url)
    last = _last_fetch_per_domain.get(domain, 0.0)
    elapsed = time.time() - last
    if elapsed < REQUEST_DELAY_SECONDS:
        time.sleep(REQUEST_DELAY_SECONDS - elapsed)
    _last_fetch_per_domain[domain] = time.time()


# %%
# =============================================================================
# Fetch — met cache, robots.txt, delay, retries
# =============================================================================

@dataclass
class FetchResult:
    """Resultaat van één fetch."""
    url: str
    status: int
    content: bytes
    content_type: str
    from_cache: bool
    error: Optional[str] = None

    @property
    def text(self) -> str:
        """Decodeer content als tekst (best effort)."""
        try:
            # Detecteer encoding via meta tags / HTTP header indien mogelijk
            return self.content.decode("utf-8", errors="replace")
        except UnicodeDecodeError:
            return self.content.decode("latin-1", errors="replace")

    @property
    def is_html(self) -> bool:
        return "html" in (self.content_type or "").lower()

    @property
    def is_pdf(self) -> bool:
        return "pdf" in (self.content_type or "").lower() or self.url.lower().endswith(".pdf")


def fetch(url: str, use_cache: bool = True) -> FetchResult:
    """Haal `url` op, met cache-ondersteuning. Gooit nooit, geeft FetchResult."""
    # Cache check
    if use_cache:
        cached = cache_get(url)
        if cached is not None:
            ct = "application/pdf" if url.lower().endswith(".pdf") else "text/html"
            log.debug("Cache-hit: %s", url)
            return FetchResult(url=url, status=200, content=cached,
                               content_type=ct, from_cache=True)

    # robots.txt
    if not robots_allows(url):
        log.info("robots.txt verbiedt %s — overgeslagen", url)
        return FetchResult(url=url, status=0, content=b"", content_type="",
                           from_cache=False, error="robots.txt disallow")

    polite_wait(url)

    try:
        resp = SESSION.get(url, timeout=REQUEST_TIMEOUT, allow_redirects=True)
    except requests.RequestException as e:
        log.warning("Fetch-fout %s: %s", url, e)
        return FetchResult(url=url, status=0, content=b"", content_type="",
                           from_cache=False, error=str(e))

    ct = resp.headers.get("Content-Type", "").lower()
    if resp.status_code == 200 and resp.content:
        cache_put(url, resp.content)
    return FetchResult(url=resp.url, status=resp.status_code,
                       content=resp.content, content_type=ct,
                       from_cache=False,
                       error=None if resp.status_code == 200 else f"HTTP {resp.status_code}")


