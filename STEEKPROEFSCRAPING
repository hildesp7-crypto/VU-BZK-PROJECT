# Crawler — BFS tot max diepte, prioriteit voor relevante paden
# =============================================================================

@dataclass
class CrawlResult:
    """Verzamelde data voor één gecrawlde site."""
    start_url: str
    pages: dict[str, str] = field(default_factory=dict)    # url -> text content
    soups: dict[str, BeautifulSoup] = field(default_factory=dict)
    pdfs: dict[str, str] = field(default_factory=dict)      # pdf url -> extracted text
    errors: list[str] = field(default_factory=list)
    visited_count: int = 0


def normalize_url(url: str) -> str:
    """Normaliseer: verwijder fragment, sorteer query niet (kan semantisch zijn)."""
    parts = urlparse.urlsplit(url)
    return urlparse.urlunsplit((parts.scheme, parts.netloc, parts.path or "/",
                                parts.query, ""))


def collect_internal_links(soup: BeautifulSoup, base_url: str) -> list[str]:
    """Verzamel interne links (zelfde geregistreerde domein) uit een soup."""
    links: list[str] = []
    for a in soup.find_all("a", href=True):
        href = a["href"].strip()
        if not href or href.startswith(("mailto:", "tel:", "javascript:", "#")):
            continue
        absolute = urlparse.urljoin(base_url, href)
        if not absolute.startswith(("http://", "https://")):
            continue
        if not is_same_registered_domain(absolute, base_url):
            continue
        path = urlparse.urlsplit(absolute).path.lower()
        # Sla niet-relevante extensies over (behalve PDF)
        if any(path.endswith(ext) for ext in SKIP_EXTENSIONS):
            continue
        links.append(normalize_url(absolute))
    return links


def is_priority_url(url: str) -> bool:
    """True als de URL een van de prioritaire paden bevat."""
    path = url_path_lower(url)
    return any(p in path for p in PRIORITY_PATHS)


def crawl_site(start_url: str,
               max_depth: int = MAX_CRAWL_DEPTH,
               max_pages: int = MAX_PAGES_PER_SITE) -> CrawlResult:
    """Crawl een website breedte-eerst tot `max_depth` en `max_pages`.

    Pagina's met prioritaire paden (ANBI, over-ons, jaarverslag, etc.) worden
    als eerste bezocht binnen elke diepte-laag.
    """
    result = CrawlResult(start_url=start_url)
    visited: set[str] = set()
    queue: deque[tuple[str, int]] = deque([(normalize_url(start_url), 0)])

    while queue and result.visited_count < max_pages:
        # Sorteer huidige queue zodat prioritaire URL's vooraan staan.
        priority = sorted(queue, key=lambda x: (not is_priority_url(x[0]), x[1]))
        queue = deque(priority)
        url, depth = queue.popleft()

        if url in visited:
            continue
        visited.add(url)
        result.visited_count += 1

        log.debug("Crawl [%d/%d, depth=%d] %s",
                  result.visited_count, max_pages, depth, url)
        try:
            res = fetch_smart(url)
        except Exception as e:                       # noqa: BLE001
            log.warning("Onverwachte fout bij %s: %s", url, e)
            result.errors.append(f"{url}: {e}")
            continue

        if res.error:
            result.errors.append(f"{url}: {res.error}")
            continue

        if res.is_pdf:
            pdf_text = extract_text_from_pdf(res)
            if pdf_text:
                result.pdfs[url] = pdf_text
                log.debug("PDF geparsed (%d chars): %s", len(pdf_text), url)
            continue

        if not res.is_html:
            continue

        try:
            soup = BeautifulSoup(res.content, "lxml")
        except Exception as e:                       # noqa: BLE001
            log.debug("Parse-fout %s: %s", url, e)
            continue

        # Verwijder script/style voor schonere tekst
        for tag in soup(["script", "style", "noscript"]):
            tag.decompose()

        page_text = soup.get_text(" ", strip=True)
        result.pages[url] = page_text
        result.soups[url] = soup

        if depth >= max_depth:
            continue

        for link in collect_internal_links(soup, url):
            if link not in visited:
                queue.append((link, depth + 1))

    # Voeg expliciet bekende prioriteits-paden toe als ze nog niet bezocht zijn.
    for p in PRIORITY_PATHS:
        candidate = normalize_url(urlparse.urljoin(start_url, p))
        if candidate not in visited and result.visited_count < max_pages:
            try:
                res = fetch_smart(candidate)
                if res.status == 200 and res.is_html:
                    soup = BeautifulSoup(res.content, "lxml")
                    for tag in soup(["script", "style", "noscript"]):
                        tag.decompose()
                    result.pages[candidate] = soup.get_text(" ", strip=True)
                    result.soups[candidate] = soup
                    result.visited_count += 1
                    log.debug("Prioriteits-pad gevonden: %s", candidate)
            except Exception:                        # noqa: BLE001
                pass

    return result


